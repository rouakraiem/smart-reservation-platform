### ============================================================
###   SMART RESERVATION PLATFORM — Tests REST (HTTP Client)
###   Compatible avec : VS Code REST Client, IntelliJ HTTP Client
### ============================================================

@base = http://localhost:3000/api

### ──────────────────────────────────────────────────────────────
### 0. HEALTH CHECK
### ──────────────────────────────────────────────────────────────

GET http://localhost:3000/health

### ──────────────────────────────────────────────────────────────
### 1. USERS
### ──────────────────────────────────────────────────────────────

# 1.1 Créer un utilisateur
POST {{base}}/users
Content-Type: application/json

{
  "name": "Alice Dupont",
  "email": "alice@example.com",
  "password": "motdepasse123"
}

###

# 1.2 Créer un deuxième utilisateur
POST {{base}}/users
Content-Type: application/json

{
  "name": "Bob Martin",
  "email": "bob@example.com",
  "password": "secret456"
}

###

# 1.3 Lister tous les utilisateurs
GET {{base}}/users

###

# 1.4 Obtenir un utilisateur par ID (remplacer USER_ID)
GET {{base}}/users/USER_ID_ICI

###

# 1.5 Mettre à jour un utilisateur
PUT {{base}}/users/USER_ID_ICI
Content-Type: application/json

{
  "name": "Alice Dupont-Martin"
}

###

# 1.6 Login
POST {{base}}/users/login
Content-Type: application/json

{
  "email": "alice@example.com",
  "password": "motdepasse123"
}

###

### ──────────────────────────────────────────────────────────────
### 2. RESOURCES (Salles, Bureaux, Terrains…)
### ──────────────────────────────────────────────────────────────

# 2.1 Créer une salle de réunion
POST {{base}}/resources
Content-Type: application/json

{
  "name": "Salle Méditerranée",
  "type": "salle_reunion",
  "capacity": 10,
  "description": "Salle équipée vidéoprojecteur et tableau blanc"
}

###

# 2.2 Créer un bureau
POST {{base}}/resources
Content-Type: application/json

{
  "name": "Bureau 204",
  "type": "bureau_individuel",
  "capacity": 1,
  "description": "Bureau calme en open space"
}

###

# 2.3 Créer un terrain de sport
POST {{base}}/resources
Content-Type: application/json

{
  "name": "Terrain A",
  "type": "terrain_sport",
  "capacity": 22,
  "description": "Terrain de football extérieur"
}

###

# 2.4 Lister toutes les ressources
GET {{base}}/resources

###

# 2.5 Voir les créneaux disponibles d'une ressource
GET {{base}}/resources/RESOURCE_ID_ICI/slots?date=2025-12-20

###

### ──────────────────────────────────────────────────────────────
### 3. RESERVATIONS
### ──────────────────────────────────────────────────────────────

# 3.1 Créer une réservation
POST {{base}}/reservations
Content-Type: application/json

{
  "user_id": "USER_ID_ICI",
  "resource_id": "RESOURCE_ID_ICI",
  "date": "2025-12-20",
  "start_time": "09:00",
  "end_time": "10:00",
  "notes": "Réunion équipe projet"
}

###

# 3.2 Lister toutes les réservations
GET {{base}}/reservations

###

# 3.3 Lister les réservations d'un utilisateur
GET {{base}}/reservations?userId=USER_ID_ICI

###

# 3.4 Obtenir une réservation par ID
GET {{base}}/reservations/RESERVATION_ID_ICI

###

# 3.5 Modifier une réservation
PUT {{base}}/reservations/RESERVATION_ID_ICI
Content-Type: application/json

{
  "date": "2025-12-21",
  "start_time": "10:00",
  "end_time": "11:00",
  "notes": "Réunion reportée au lendemain"
}

###

# 3.6 Annuler une réservation
DELETE {{base}}/reservations/RESERVATION_ID_ICI

###

### ──────────────────────────────────────────────────────────────
### 4. NOTIFICATIONS
### ──────────────────────────────────────────────────────────────

# 4.1 Récupérer les notifications d'un utilisateur
GET {{base}}/notifications?userId=USER_ID_ICI

###

# 4.2 Marquer une notification comme lue
PATCH {{base}}/notifications/NOTIFICATION_ID_ICI/read

###

# 4.3 Créer une notification manuelle (admin)
POST {{base}}/notifications
Content-Type: application/json

{
  "user_id": "USER_ID_ICI",
  "type": "info",
  "message": "Maintenance prévue le 25 décembre de 2h à 4h."
}

###
